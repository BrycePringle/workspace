<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             x:DataType="viewmodels:ItemDetailViewModel"
             Title="Item Detail">

    <ScrollView>
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackLayout Grid.Row="0" Spacing="15">

                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                       Padding="20"
                       CornerRadius="12"
                       HasShadow="True">
                    <StackLayout Spacing="15">

                        <Label Text="Title" FontSize="14" FontAttributes="Bold"/>
                        <Label Text="{Binding Item.Title}" FontSize="18"/>

                        <Label Text="Description" FontSize="14" FontAttributes="Bold" Margin="0,10,0,0"/>
                        <Label Text="{Binding Item.Description}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>

                        <Label Text="Daily Rate" FontSize="14" FontAttributes="Bold" Margin="0,10,0,0"/>
                        <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} / day'}" FontSize="16" TextColor="DodgerBlue"/>

                        <Label Text="Category" FontSize="14" FontAttributes="Bold" Margin="0,10,0,0"/>
                        <Label Text="{Binding Item.Category}" FontSize="16"/>

                        <Label Text="Location" FontSize="14" Margin="0,10,0,0"/>
                        <Label Text="{Binding Item.Location}" FontSize="16"/>
                    </StackLayout>
                </Frame>

            </StackLayout>

            <StackLayout Grid.Row="1"
                         Margin="0,20,0,0">
                <Button Text="Back"
                        Command="{Binding BackCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray700}}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                        FontSize="16"
                        CornerRadius="8"
                        HeightRequest="50" />
            </StackLayout>

        </Grid>
    </ScrollView>
</ContentPage>