<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             x:DataType="viewmodels:ItemDetailViewModel"
             Title="Item Detail">

<ScrollView>
    <VerticalStackLayout Padding="20" Spacing="20">

        <!-- top half -->
        <Frame BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
               Padding="20"
               CornerRadius="12"
               HasShadow="True">

            <VerticalStackLayout Spacing="15">

                <Label Text="Title" FontAttributes="Bold"/>
                <Label Text="{Binding Item.Title}" FontSize="18"/>

                <Label Text="Description" FontAttributes="Bold"/>
                <Label Text="{Binding Item.Description}"/>

                <Label Text="Daily Rate" FontAttributes="Bold"/>
                <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} / day'}" TextColor="DodgerBlue"/>

                <Label Text="Category" FontAttributes="Bold"/>
                <Label Text="{Binding Item.Category}"/>
            </VerticalStackLayout>
        </Frame>

        <!-- ERROR -->
        <Border BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                StrokeThickness="1"
                Padding="15"
                IsVisible="{Binding HasError}">
            <Label Text="{Binding ErrorMessage}" />
        </Border>

        <!-- START DATE -->
        <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">

            <Entry Text="{Binding StartDate}"
                   Placeholder="Start Date (XX/XX/XXXX)"
                   Margin="15,10"/>
        </Border>

        <!-- END DATE -->
        <Border Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                StrokeThickness="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">

            <Entry Text="{Binding EndDate}"
                   Placeholder="End Date (XX/XX/XXXX)"
                   Margin="15,10"/>
        </Border>

        <!-- BUTTON -->
        <Button Text="Rent This Item"
                Command="{Binding CreateRentalCommand}"
                HeightRequest="50"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                TextColor="White"/>

    </VerticalStackLayout>
</ScrollView>
</ContentPage>